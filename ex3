import sys


def secure_archive(
    filename: str, action: str = "read", content: str = ""
) -> tuple[bool, str]:
    """Provides safe access to a file for reading or writing using a context manager."""
    try:
        if action == "read":
            with open(filename, "r") as f:
                data = f.read()
            return True, data

        elif action == "write":
            with open(filename, "w") as f:
                f.write(content)
            return True, "Content successfully written to file"

        else:
            return False, f"Unknown action: '{action}'"

    except Exception as e:
        return False, str(e)


def main() -> None:
    """Gets the filename from command line arguments and tests secure_archive."""
    if len(sys.argv) < 2:
        print("Usage: python3 ft_vault_security.py <filename>")
        return

    target_file = sys.argv[1]

    print("=== Cyber Archives Security ===")

    print(f"Using 'secure_archive' to read from file '{target_file}':")
    success, result = secure_archive(target_file, "read")
    print((success, result))

    if success:
        print("\nUsing 'secure_archive' to write previous content to a new file:")
        write_res = secure_archive("backup_" + target_file, "write", result)
        print(write_res)


if __name__ == "__main__":
    main()
