import sys


def secure_archive(
    filename: str,
    action: str = "read",
    content: str = ""
) -> tuple[bool, str]:
    if action == "write":
        try:
            with open(filename, "w") as file:
                file.write(content)
            return True, "Content successfully written to file"
        except Exception as e:
            return False, str(e)

    try:
        with open(filename, "r") as file:
            data: str = file.read()
        return True, data
    except Exception as e:
        return False, str(e)


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: python3 ft_vault_security.py <filename>")
        sys.exit(1)

    user_file: str = sys.argv[1]
    print("=== Cyber Archives Security ===")

    success, result = secure_archive(user_file, "read")

    if success:
        print("Using 'secure_archive' to read from a regular file:")
        print((True, result))
    else:
        err_msg = result.lower()

        if "permission denied" in err_msg or "denied" in err_msg:
            print("Using 'secure_archive' to read from an inaccessible file:")
            print((False, result))
        else:
            print("Using 'secure_archive' to read from a nonexistent file:")
            print((False, result))

            print("\nUsing 'secure_archive' to write previous content to a new file:")
            write_status, write_res = secure_archive(
                user_file,
                "write",
                "New content saved to the vault."
            )
            print((write_status, write_res))


if __name__ == "__main__":
    main()
